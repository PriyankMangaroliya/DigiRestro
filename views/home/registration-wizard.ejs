<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digirestro - Premium Registration Wizard</title>

    <!-- External Fonts & Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/assets/css/main-light.css">

    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --primary-color: #0061f2;
            --primary-light: #e0e9ff;
            --secondary-color: #69707a;
            --bg-gradient: linear-gradient(135deg, #f2f5f9 0%, #ffffff 100%);
            --glass-bg: rgba(255, 255, 255, 0.9);
            --glass-border: #edf2f9;
            --text-color: #2d3436;
            --input-bg: #f8fafc;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
        }

        body {
            background: var(--bg-gradient);
            background-attachment: fixed;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
            overflow-x: hidden;
            color: var(--text-color);
        }

        .background-blob {
            position: fixed;
            width: 500px;
            height: 500px;
            background: var(--primary-color);
            filter: blur(150px);
            opacity: 0.1;
            z-index: -1;
            border-radius: 50%;
        }

        .blob-1 {
            top: -100px;
            left: -100px;
        }

        .blob-2 {
            bottom: -100px;
            right: -100px;
        }

        .registration-container {
            width: 100%;
            max-width: 900px;
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.37);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            transform-style: preserve-3d;
            perspective: 1000px;
        }

        @media (min-width: 768px) {
            .registration-container {
                flex-direction: row;
                height: 650px;
            }
        }

        /* Sidebar Info Area */
        .sidebar-info {
            background: rgba(255, 255, 255, 0.4);
            padding: 40px;
            flex: 0 0 320px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            gap: 30px;
            border-right: 1px solid var(--glass-border);
        }

        .sidebar-info h2 {
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 10px;
            letter-spacing: -1px;
            color: var(--text-color);
        }

        .sidebar-info h2 span {
            color: var(--primary-color);
        }

        .sidebar-info p {
            opacity: 0.7;
            line-height: 1.6;
            font-size: 14px;
            color: var(--secondary-color);
        }

        .step-progress {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-top: 20px;
        }

        .step-item {
            display: flex;
            align-items: center;
            gap: 15px;
            opacity: 0.4;
            transition: all 0.4s ease;
            color: var(--secondary-color);
        }

        .step-item.active {
            opacity: 1;
            transform: translateX(10px);
            color: var(--primary-color);
        }

        .step-item.completed {
            opacity: 1;
            color: var(--primary-color);
        }

        .step-circle {
            width: 35px;
            height: 35px;
            border-radius: 10px;
            border: 2px solid currentColor;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
        }

        .step-item.completed .step-circle {
            background: var(--primary-color);
            border-color: var(--primary-color);
            color: white;
        }

        /* Main Form Area */
        .form-content {
            flex: 1;
            padding: 40px;
            position: relative;
            overflow-y: auto;
            background: white;
        }

        .form-step {
            display: none;
            flex-direction: column;
            gap: 15px;
            animation: fadeInRight 0.5s ease-out forwards;
        }

        .form-step.active {
            display: flex;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            width: 100%;
        }

        .form-row {
            display: flex;
            gap: 15px;
            width: 100%;
        }

        .form-row>.form-group {
            flex: 1;
        }

        label {
            font-size: 12px;
            font-weight: 700;
            opacity: 0.8;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--secondary-color);
        }

        input,
        select,
        textarea {
            background: var(--input-bg);
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 12px 16px;
            color: var(--text-color);
            font-size: 14px;
            transition: all 0.3s ease;
            outline: none;
        }

        input:focus,
        select:focus,
        textarea:focus {
            border-color: var(--primary-color);
            background: white;
            box-shadow: 0 0 0 4px var(--primary-light);
        }

        input::placeholder {
            color: rgba(255, 255, 255, 0.4);
        }

        .btn-container {
            margin-top: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 15px;
        }

        .btn-primary {
            background: var(--primary-color);
            color: white;
            border: none;
            padding: 14px 30px;
            border-radius: 50px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(243, 135, 9, 0.3);
            flex: 1;
            text-align: center;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn-primary:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(243, 135, 9, 0.5);
        }

        .btn-outline {
            background: transparent;
            color: var(--secondary-color);
            border: 1px solid var(--glass-border);
            padding: 14px 30px;
            border-radius: 50px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .btn-outline:hover {
            background: #f8fafc;
            border-color: var(--primary-color);
            color: var(--primary-color);
        }

        /* OTP Input Styling */
        .otp-container {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            max-width: 350px;
            margin: 20px auto;
        }

        .otp-input {
            width: 45px;
            height: 55px;
            text-align: center;
            font-size: 24px;
            font-weight: 700;
            border-radius: 10px;
            padding: 0;
        }

        /* Step Animations */
        @keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .loader {
            display: none;
            width: 18px;
            height: 18px;
            border: 2.5px solid rgba(255, 255, 255, .3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading .loader {
            display: block;
        }

        .loading span {
            display: none;
        }

        /* Custom Scrollbar */
        .form-content::-webkit-scrollbar {
            width: 6px;
        }

        .form-content::-webkit-scrollbar-track {
            background: transparent;
        }

        .form-content::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }

        .plan-badge {
            background: var(--primary-color);
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            display: inline-block;
            margin-bottom: 10px;
        }
    </style>
</head>

<body>

    <div class="background-blob blob-1"></div>
    <div class="background-blob blob-2"></div>

    <div class="registration-container animate__animated animate__zoomIn">
        <!-- Sidebar -->
        <div class="sidebar-info">
            <div>
                <div class="plan-badge">Selected Plan: <%= typeof subscriptionTitle !=='undefined' ? subscriptionTitle
                        : 'Premium' %>
                </div>
                <h2>Digi<span>Restro</span></h2>
                <p>Join thousands of restaurants growing with DigiRestro. Your journey to smart automation starts here.
                </p>
            </div>

            <ul class="step-progress">
                <li class="step-item active" id="p-step-1">
                    <div class="step-circle">1</div>
                    <div>
                        <strong>Owner Info</strong>
                        <div style="font-size: 11px; opacity: 0.6;">Profile setup</div>
                    </div>
                </li>
                <li class="step-item" id="p-step-2">
                    <div class="step-circle">2</div>
                    <div>
                        <strong>Verify</strong>
                        <div style="font-size: 11px; opacity: 0.6;">OTP validation</div>
                    </div>
                </li>
                <li class="step-item" id="p-step-3">
                    <div class="step-circle">3</div>
                    <div>
                        <strong>Company</strong>
                        <div style="font-size: 11px; opacity: 0.6;">Business brand</div>
                    </div>
                </li>
                <li class="step-item" id="p-step-4">
                    <div class="step-circle">4</div>
                    <div>
                        <strong>Outlet</strong>
                        <div style="font-size: 11px; opacity: 0.6;">Branch & Payment</div>
                    </div>
                </li>
            </ul>

            <div style="margin-top: auto; font-size: 12px; opacity: 0.5;">
                Securely processed by Razorpay & SSL Encrypted
            </div>
        </div>

        <!-- Main Content -->
        <div class="form-content">

            <!-- Step 1: Owner Info -->
            <form id="form-owner" class="form-step active">
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 24px;">Owner Registration</h3>
                    <p style="font-size: 13px; opacity: 0.6;">Create your administrative account</p>
                </div>

                <input type="hidden" name="id" value="<%= typeof decodedId !== 'undefined' ? decodedId : '' %>">

                <div class="form-group">
                    <label>Full Name</label>
                    <input type="text" name="name" placeholder="Enter your full name" required>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" name="email_id" placeholder="email@address.com" required>
                    </div>
                    <div class="form-group">
                        <label>Mobile Number</label>
                        <input type="text" name="mobile_no" placeholder="10-digit number" required maxlength="10">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Password</label>
                        <input type="password" name="password" placeholder="At least 8 characters" required
                            minlength="8">
                    </div>
                    <div class="form-group">
                        <label>Confirm Password</label>
                        <input type="password" name="cpassword" placeholder="Re-type password" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Profile Image</label>
                    <input type="file" name="image" accept="image/*">
                </div>

                <div class="btn-container">
                    <button type="submit" class="btn-primary" id="btn-owner">
                        <div class="loader"></div>
                        <span>Continue to OTP <i class="mai-chevron-forward-outline"></i></span>
                    </button>
                </div>
            </form>

            <!-- Step 2: OTP Verification -->
            <form id="form-otp" class="form-step">
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 24px;">Confirm OTP</h3>
                    <p style="font-size: 13px; opacity: 0.6;">We've sent a 6-digit code to your email</p>
                </div>

                <div class="otp-container">
                    <input type="text" class="otp-input" maxlength="1" name="first" required>
                    <input type="text" class="otp-input" maxlength="1" name="second" required>
                    <input type="text" class="otp-input" maxlength="1" name="third" required>
                    <input type="text" class="otp-input" maxlength="1" name="fourth" required>
                    <input type="text" class="otp-input" maxlength="1" name="fifth" required>
                    <input type="text" class="otp-input" maxlength="1" name="sixth" required>
                </div>

                <div class="btn-container">
                    <button type="button" class="btn-outline" onclick="prevStep(1)">Back</button>
                    <button type="submit" class="btn-primary" id="btn-otp">
                        <div class="loader"></div>
                        <span>Verify OTP <i class="mai-checkbox-outline"></i></span>
                    </button>
                </div>
                <p style="text-align: center; font-size: 13px; margin-top: 20px; opacity: 0.7;">
                    Didn't receive it? <a href="javascript:void(0)" onclick="resendOTP()"
                        style="color: var(--primary-color); font-weight: 600; text-decoration: none;">Resend Code</a>
                </p>
            </form>

            <!-- Step 3: Company Details -->
            <form id="form-company" class="form-step">
                <div style="margin-bottom: 20px;">
                    <h3 style="font-size: 24px;">Company Details</h3>
                    <p style="font-size: 13px; opacity: 0.6;">Tell us about your brand</p>
                </div>

                <div class="form-group">
                    <label>Company Display Name</label>
                    <input type="text" name="company_name" placeholder="e.g. Olive Garden" required>
                </div>

                <div class="form-group">
                    <label>Legal Entity Name</label>
                    <input type="text" name="legal_name" placeholder="e.g. Olive Garden Foods Pvt Ltd" required>
                </div>

                <div class="form-group">
                    <label>Brand Logo</label>
                    <input type="file" name="image" required accept="image/*">
                </div>

                <div class="btn-container">
                    <button type="button" class="btn-outline" onclick="prevStep(2)">Back</button>
                    <button type="submit" class="btn-primary" id="btn-company">
                        <div class="loader"></div>
                        <span>Setup First Outlet <i class="mai-storefront-outline"></i></span>
                    </button>
                </div>
            </form>

            <!-- Step 4: Branch Details -->
            <form id="form-branch" class="form-step">
                <div style="margin-bottom: 15px;">
                    <h3 style="font-size: 24px;">Outlet Configuration</h3>
                    <p style="font-size: 13px; opacity: 0.6;">Configure your primary branch</p>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Outlet Name</label>
                        <input type="text" name="branch_name" placeholder="Main Branch" required>
                    </div>
                    <div class="form-group">
                        <label>Manager Name</label>
                        <input type="text" name="name" placeholder="Branch Manager" required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Outlet Email</label>
                        <input type="email" name="email_id" placeholder="branch@email.com" required>
                    </div>
                    <div class="form-group">
                        <label>Outlet Mobile</label>
                        <input type="text" name="mobile_no" placeholder="10-digit mobile" required maxlength="10">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>Outlet Password</label>
                        <input type="password" name="password" placeholder="Branch login password" required
                            minlength="6">
                    </div>
                    <div class="form-group">
                        <label>Confirm Password</label>
                        <input type="password" name="c_password" required>
                    </div>
                </div>

                <div class="form-group">
                    <label>Street Address</label>
                    <textarea name="street_address" rows="2" placeholder="Full address of the outlet"
                        required></textarea>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label>State</label>
                        <select name="state" required>
                            <option value="Gujarat">Gujarat</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>City</label>
                        <select name="city" required>
                            <option value="Surat">Surat</option>
                            <option value="Ahmedabad">Ahmedabad</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Pincode</label>
                        <input type="text" name="pin_code" placeholder="6-digit" required maxlength="6">
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group" style="flex: 2;">
                        <label>GST Number</label>
                        <input type="text" name="gst_no" placeholder="GSTIN" required>
                    </div>
                    <div class="form-group" style="flex: 1;">
                        <label>Outlet Logo</label>
                        <input type="file" name="image" style="padding: 10px;">
                    </div>
                </div>

                <input type="hidden" name="country" value="India">

                <div class="btn-container">
                    <button type="button" class="btn-outline" onclick="prevStep(3)">Back</button>
                    <button type="submit" class="btn-primary" id="btn-branch">
                        <div class="loader"></div>
                        <span>Proceed to Payment <i class="mai-card-outline"></i></span>
                    </button>
                </div>
            </form>

        </div>
    </div>

    <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.6.4/jquery.min.js"></script>
    <script src="https://checkout.razorpay.com/v1/checkout.js"></script>

    <script>
        let currentStep = 1;

        // Helper: Step Display
        function showStep(step) {
            $('.form-step').removeClass('active');
            $(`#form-${getStepName(step)}`).addClass('active');

            $(`.step-item`).removeClass('active completed');
            for (let i = 1; i <= 4; i++) {
                if (i < step) $(`#p-step-${i}`).addClass('completed');
                if (i === step) $(`#p-step-${i}`).addClass('active');
            }
            currentStep = step;
            $('.form-content').scrollTop(0);
        }

        function getStepName(step) {
            return ['', 'owner', 'otp', 'company', 'branch'][step];
        }

        function prevStep(step) {
            showStep(step);
        }

        // OTP Navigation
        $('.otp-input').on('keyup', function (e) {
            if (this.value.length === 1) {
                $(this).next('.otp-input').focus();
            }
            if (e.key === 'Backspace' && this.value.length === 0) {
                $(this).prev('.otp-input').focus();
            }
        });

        // Success Toast
        const Toast = Swal.mixin({
            toast: true,
            position: 'top-end',
            showConfirmButton: false,
            timer: 3000,
            timerProgressBar: true
        });

        // Step 1: Owner Registration
        $('#form-owner').on('submit', function (e) {
            e.preventDefault();
            const btn = $('#btn-owner');
            const pass = $('input[name="password"]').val();
            const cpass = $('input[name="cpassword"]').val();

            if (pass !== cpass) {
                Swal.fire('Mismatch', 'Passwords do not match!', 'warning');
                return;
            }

            btn.parent().addClass('loading');
            btn.prop('disabled', true);

            const formData = new FormData(this);

            $.ajax({
                url: "/registration",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    Toast.fire({ icon: 'success', title: 'OTP sent to your email' });
                    showStep(2);
                },
                error: function (err) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    const msg = (err.responseJSON && err.responseJSON.message) ? err.responseJSON.message : 'Registration failed. Please try again.';
                    Swal.fire('Oops!', msg, 'error');
                }
            });
        });

        // Step 2: OTP Verification
        $('#form-otp').on('submit', function (e) {
            e.preventDefault();
            const btn = $('#btn-otp');
            btn.parent().addClass('loading');
            btn.prop('disabled', true);

            const formData = $(this).serialize();

            $.ajax({
                url: "/otpVerification",
                type: "POST",
                data: formData,
                success: function (res) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    if (res.success) {
                        Toast.fire({ icon: 'success', title: 'Email verified successfully' });
                        showStep(3);
                    } else {
                        clearOTP();
                        Swal.fire('Invalid OTP', res.message || 'The code you entered is incorrect.', 'error');
                    }
                },
                error: function (err) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    clearOTP();
                    const msg = (err.responseJSON && err.responseJSON.message) ? err.responseJSON.message : 'Verification failed.';
                    Swal.fire('Error', msg, 'error');
                }
            });
        });

        // Step 3: Company Registration
        $('#form-company').on('submit', function (e) {
            e.preventDefault();
            const btn = $('#btn-company');
            btn.parent().addClass('loading');
            btn.prop('disabled', true);

            const formData = new FormData(this);

            $.ajax({
                url: "/register-company",
                type: "POST",
                data: formData,
                processData: false,
                contentType: false,
                success: function (res) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    Toast.fire({ icon: 'success', title: 'Company details saved' });
                    showStep(4);
                },
                error: function (err) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    const msg = (err.responseJSON && err.responseJSON.message) ? err.responseJSON.message : 'Could not save company details.';
                    Swal.fire('Error', msg, 'error');
                }
            });
        });

        // Step 4: Branch Registration & Razorpay
        $('#form-branch').on('submit', function (e) {
            e.preventDefault();
            const btn = $('#btn-branch');
            const pass = $('#form-branch input[name="password"]').val();
            const cpass = $('#form-branch input[name="c_password"]').val();
            const gstin = $('#form-branch input[name="gst_no"]').val();

            if (pass !== cpass) {
                Swal.fire('Mismatch', 'Branch passwords do not match!', 'warning');
                return;
            }

            // GST Validation (Optional but recommended if you want to keep the same logic)
            // if(!validateGSTIN(gstin)) {
            //     Swal.fire('Invalid GSTIN', 'Please enter a valid GST number.', 'warning');
            //     return;
            // }

            btn.parent().addClass('loading');
            btn.prop('disabled', true);

            const formData = $(this).serialize();

            $.ajax({
                url: "/register-branch",
                type: "POST",
                data: formData,
                success: function (res) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    if (res.success) {
                        var options = {
                            key: res.key_id,
                            amount: res.amount,
                            currency: "INR",
                            name: "Digirestro",
                            description: res.description,
                            image: "/admin/assets/img/favicon.ico",
                            order_id: res.order_id,
                            handler: function (response) {
                                Toast.fire({ icon: 'success', title: 'Payment Successful!' });
                                setTimeout(() => {
                                    window.location.href = "/register-purchased-subscription";
                                }, 1500);
                            },
                            prefill: {
                                contact: res.contact,
                                name: res.name,
                                email: res.email,
                            },
                            notes: { description: res.description },
                            theme: { color: "#f38709" }
                        };
                        var rzp = new Razorpay(options);
                        rzp.on("payment.failed", function (response) {
                            Swal.fire('Payment Failed', response.error.description, 'error');
                        });
                        rzp.open();
                    } else {
                        Swal.fire('Error', res.msg || 'Branch setup failed.', 'error');
                    }
                },
                error: function (err) {
                    btn.parent().removeClass('loading');
                    btn.prop('disabled', false);
                    Swal.fire('Error', 'Network error during branch setup.', 'error');
                }
            });
        });

        function validateGSTIN(gstin) {
            const gstinRegex = /^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}[0-9]{1}$/;
            if (!gstinRegex.test(gstin)) return false;

            const stateCode = gstin.substring(0, 2);
            if (parseInt(stateCode) === 0) return false;

            return true;
        }

        function resendOTP() {
            $.ajax({
                url: "/resendOTP",
                type: "POST",
                success: function () {
                    Toast.fire({ icon: 'success', title: 'New OTP sent to email' });
                }
            });
        }
        
        function clearOTP() {
            $('.otp-input').val('');
            $('.otp-input').first().focus();
        }
    </script>

</body>

</html>