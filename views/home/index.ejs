<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digirestro - Smart Restaurant Management</title>

    <!-- Bootstrap 5.3.3 CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="./assets/css/main-light.css" />
    <link rel="shortcut icon" type="image/x-icon" href="../admin/assets/img/favicon.ico" />
</head>

<body style="padding-top: 90px;">

    <!-- Back to top button -->
    <div class="back-to-top"></div>

    <header>
        <nav class="navbar navbar-expand-lg fixed-top bg-white py-3 shadow-sm">
            <div class="container">
                <a href="/" class="navbar-brand fw-bold fs-3 letter-spacing-tight">Digi<span
                        class="text-primary">restro</span></a>

                <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarContent">
                    <i class="bi bi-list fs-4"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav ms-auto gap-lg-4 mb-2 mb-lg-0 align-items-center">
                        <li class="nav-item"><a href="#home" class="nav-link fw-semibold active">Home</a></li>
                        <li class="nav-item"><a href="#software" class="nav-link fw-semibold">Features</a></li>
                        <li class="nav-item"><a href="#pricing" class="nav-link fw-semibold">Pricing</a></li>
                        <li class="nav-item"><a href="#contact" class="nav-link fw-semibold">Contact</a></li>
                    </ul>
                    <div class="ms-lg-4 d-flex justify-content-center">
                        <a href="/home/auth-login" class="btn btn-outline-primary px-4 fw-bold rounded-pill">Login</a>
                    </div>
                </div>
            </div>
        </nav>

        <div class="home-banner py-5" id="home">
            <div class="container py-lg-5">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 wow fadeInUp">
                        <h1 class="display-3 fw-bold mb-4">Increase Profit & <span class="text-primary">Automate</span>
                            Your Restaurant</h1>
                        <p class="lead text-secondary mb-5 pe-lg-5">Your Restaurant’s Technology Partner. Grow revenue
                            and manage inventory, billing, and staff seamlessly with our all-in-one platform.</p>
                        <div class="d-flex flex-wrap gap-3">
                            <a href="#pricing"
                                class="btn btn-primary btn-lg rounded-pill px-5 py-3 fw-bold shadow-lg">Get Started</a>
                            <a href="#" class="btn btn-outline-primary btn-lg rounded-pill px-5 py-3 fw-bold">Watch Demo
                                <i class="bi bi-play-fill ms-2"></i></a>
                        </div>
                    </div>
                    <div class="col-lg-6 wow zoomIn shadow-hover">
                        <div class="img-hero-container">
                            <img src="./assets/img/hero-dashboard.png" alt="DigiRestro Dashboard"
                                class="img-fluid rounded-5 shadow-lg">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main>
        <!-- Features Summary -->
        <div class="page-section bg-light py-5" id="choose">
            <div class="container py-lg-5">
                <div class="text-center wow fadeInUp mb-5">
                    <div class="subhead text-primary fw-bold text-uppercase mb-2" style="letter-spacing: 2px;">Built for
                        Growth</div>
                    <h2 class="display-5 fw-bold text-dark">Your Comfort is Our Priority</h2>
                    <div class="divider bg-primary mx-auto my-4" style="width: 50px; height: 5px; border-radius: 10px;">
                    </div>
                </div>

                <div class="row g-4 mt-2">
                    <div class="col-lg-4 col-md-6 wow fadeInUp">
                        <div
                            class="feature-card h-100 p-5 bg-white rounded-4 border-0 shadow-sm transition-all hover-translate-y">
                            <div class="feature-icon mb-4 d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-3"
                                style="width: 70px; height: 70px;">
                                <i class="bi bi-speedometer2 fs-3"></i>
                            </div>
                            <h4 class="fw-bold mb-3">High Performance</h4>
                            <p class="text-secondary mb-0">Process orders and generate bills in seconds with our
                                lightning-fast engine.</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 wow fadeInUp">
                        <div
                            class="feature-card h-100 p-5 bg-white rounded-4 border-0 shadow-sm transition-all hover-translate-y">
                            <div class="feature-icon mb-4 d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-3"
                                style="width: 70px; height: 70px;">
                                <i class="bi bi-tag fs-3"></i>
                            </div>
                            <h4 class="fw-bold mb-3">Smart Pricing</h4>
                            <p class="text-secondary mb-0">Subscription plans tailored for every food business, from
                                cafes to large chains.</p>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6 wow fadeInUp">
                        <div
                            class="feature-card h-100 p-5 bg-white rounded-4 border-0 shadow-sm transition-all hover-translate-y">
                            <div class="feature-icon mb-4 d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-3"
                                style="width: 70px; height: 70px;">
                                <i class="bi bi-clock fs-3"></i>
                            </div>
                            <h4 class="fw-bold mb-3">24/7 Support</h4>
                            <p class="text-secondary mb-0">Our personal support team is ready to help you whenever your
                                business is open.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Product Showcase -->
        <div class="page-section py-5" id="software">
            <div class="container py-lg-5">
                <div class="row align-items-center g-5">
                    <div class="col-lg-6 wow zoomIn">
                        <img src="./assets/img/bg_image_2.png" alt="Smart App" class="img-fluid rounded-5 shadow-lg">
                    </div>
                    <div class="col-lg-6 wow fadeInRight">
                        <div class="subhead text-primary fw-bold text-uppercase mb-2" style="letter-spacing: 1px;">
                            Powerful Software</div>
                        <h2 class="display-6 fw-bold text-dark mb-4">Best Restaurant Management App</h2>
                        <div class="divider bg-primary mb-4" style="width: 50px; height: 5px; border-radius: 10px;">
                        </div>
                        <p class="text-secondary mb-4 fs-5">Automate your restaurant reports and go paper-free! Let
                            DigiRestro track your activities and provide error-free reports on daily sales, orders, and
                            business health.</p>
                        <ul class="list-unstyled mb-5">
                            <li class="mb-3 d-flex align-items-center text-dark fw-medium"><i
                                    class="bi bi-award-fill text-primary me-3 fs-5"></i> Real-time order tracking</li>
                            <li class="mb-3 d-flex align-items-center text-dark fw-medium"><i
                                    class="bi bi-award-fill text-primary me-3 fs-5"></i> Automatic KOT generation</li>
                            <li class="mb-3 d-flex align-items-center text-dark fw-medium"><i
                                    class="bi bi-award-fill text-primary me-3 fs-5"></i> Digital payments integration</li>
                        </ul>
                        <a href="#pricing" class="btn btn-primary px-5 py-3 fw-bold rounded-pill shadow">Choose a
                            Plan</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing Section -->
        <div class="page-section bg-light py-5" id="pricing">
            <div class="container py-lg-5">
                <div class="text-center wow fadeInUp mb-5">
                    <div class="subhead text-primary fw-bold text-uppercase mb-2">Simple Pricing</div>
                    <h2 class="display-6 fw-bold text-dark">Find the Right Plan</h2>
                    <div class="divider bg-primary mx-auto my-4" style="width: 50px; height: 5px; border-radius: 10px;">
                    </div>
                </div>

                <div class="row g-4 justify-content-center mt-4">
                    <% for (let i=0; i < subscriptions.length; i++) { %>
                        <div class="col-lg-4 col-md-6 wow fadeInUp">
                            <div class="card h-100 border-0 rounded-4 shadow-sm p-4 p-lg-5 transition-all hover-translate-y <%= i === 1 ? 'border-primary border-3' : '' %>"
                                style="position: relative;">
                                <% if(i===1) { %>
                                    <div class="badge bg-primary text-white fs-6 py-2 px-3 rounded-pill"
                                        style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%);">
                                        Most Popular</div>
                                    <% } %>
                                        <div class="card-body text-center">
                                            <h4 class="fw-bold mb-4">
                                                <%= subscriptions[i].title %>
                                            </h4>
                                            <p class="text-secondary mb-5">
                                                <%= subscriptions[i].description %>
                                            </p>
                                            <div class="price-display mb-5">
                                                <span class="fs-1 fw-bold text-dark"><span
                                                        class="fs-4 fw-medium text-dark pe-1">₹</span>
                                                    <%= subscriptions[i].price %>
                                                </span>
                                                <div class="text-secondary small">per outlet / subscription</div>
                                            </div>
                                            <div class="d-grid pt-3">
                                                <a href="/home/subscription?id=<%= btoa(subscriptions[i]._id) %>"
                                                    class="btn <%= i === 1 ? 'btn-primary' : 'btn-outline-primary' %> py-3 fw-bold rounded-pill mx-auto px-5 w-auto">Select
                                                    Plan</a>
                                            </div>
                                        </div>
                            </div>
                        </div>
                        <% } %>
                </div>
            </div>
        </div>

        <!-- Contact Section -->
        <div class="page-section py-5" id="contact">
            <div class="container py-lg-5">
                <div class="row justify-content-center g-5">
                    <div class="col-lg-8 text-center wow fadeInUp mb-4">
                        <div class="subhead text-primary fw-bold text-uppercase mb-2">Get In Touch</div>
                        <h2 class="display-6 fw-bold text-dark">How can we help?</h2>
                        <div class="divider bg-primary mx-auto my-4"
                            style="width: 50px; height: 5px; border-radius: 10px;"></div>
                    </div>

                    <div class="col-lg-11">
                        <div class="row g-4 justify-content-center mb-5">
                            <div class="col-lg-4 col-md-6 wow fadeInUp">
                                <div class="feature-card h-100 p-4 bg-white rounded-4 border shadow-sm text-center">
                                    <div class="feature-icon mb-3 d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-pill mb-3"
                                        style="width: 60px; height: 60px;">
                                        <i class="bi bi-envelope fs-4"></i>
                                    </div>
                                    <h6 class="fw-bold mb-1">Email Us</h6>
                                    <p class="text-secondary mb-0">info@digirestro.com</p>
                                </div>
                            </div>
                            <div class="col-lg-4 col-md-6 wow fadeInUp">
                                <div class="feature-card h-100 p-4 bg-white rounded-4 border shadow-sm text-center">
                                    <div class="feature-icon mb-3 d-inline-flex align-items-center justify-content-center bg-primary-subtle text-primary rounded-pill mb-3"
                                        style="width: 60px; height: 60px;">
                                        <i class="bi bi-phone fs-4"></i>
                                    </div>
                                    <h6 class="fw-bold mb-1">Call Us</h6>
                                    <p class="text-secondary mb-0">+91 88492 88573</p>
                                </div>
                            </div>
                        </div>

                        <div class="p-5 p-lg-5 bg-white border rounded-5 shadow-sm wow fadeInUp">
                            <form action="/home/contact-us" method="post" class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-dark">Full Name</label>
                                    <input type="text"
                                        class="form-control form-control-lg bg-light rounded-3 border-0 py-3 px-4"
                                        placeholder="Enter your name" name="name" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-dark">Email Address</label>
                                    <input type="email"
                                        class="form-control form-control-lg bg-light rounded-3 border-0 py-3 px-4"
                                        placeholder="Enter your email" name="email_id" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-dark">Contact Number</label>
                                    <input type="text"
                                        class="form-control form-control-lg bg-light rounded-3 border-0 py-3 px-4"
                                        placeholder="10-digit mobile number" name="mobile_no" required>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold text-dark">Subject</label>
                                    <input type="text"
                                        class="form-control form-control-lg bg-light rounded-3 border-0 py-3 px-4"
                                        placeholder="Topic of inquiry" name="subject" required>
                                </div>
                                <div class="col-12">
                                    <label class="form-label fw-semibold text-dark">Message</label>
                                    <textarea class="form-control form-control-lg bg-light rounded-3 border-0 py-3 px-4"
                                        placeholder="Tell us more about your needs..." name="message" rows="4"
                                        required></textarea>
                                </div>
                                <div class="text-center mt-5">
                                    <button class="btn btn-primary px-5 py-3 fw-bold rounded-pill shadow-lg">Send
                                        Message</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <footer class="page-footer bg-dark py-5 mt-5">
        <div class="container py-4">
            <div class="row align-items-center mb-5">
                <div class="col-lg-6 mb-4 mb-lg-0 text-center text-lg-start">
                    <h2 class="text-white fw-bold mb-2">Digi<span class="text-primary">restro</span></h2>
                    <p class="text-secondary mb-0">Modernizing one restaurant at a time. The ultimate partner for your
                        smart food business goals.</p>
                </div>

            </div>

            <hr class="border-secondary opacity-25 mb-4">

            <div class="row text-center text-md-start">
                <div class="col-md-12 mb-3 mb-md-0">
                    <p class="text-secondary small mb-0">&copy; 2026 DigiRestro. Built for the modern kitchen. All
                        rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <!-- Bootstrap 5 Bundle JS CDN -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="./assets/js/jquery-3.5.1.min.js"></script>
    <script src="./assets/vendor/wow/wow.min.js"></script>
    <script src="./assets/vendor/waypoints/jquery.waypoints.min.js"></script>
    <script src="./assets/vendor/animateNumber/jquery.animateNumber.min.js"></script>
    <script src="./assets/js/theme.js"></script>

    <script>
        $(document).ready(function () {
            new WOW().init();

            // Stats counter trigger logic if needed ...
        });

        $(window).scroll(function () {
            if ($(this).scrollTop() > 100) {
                $('.back-to-top').css('visibility', 'visible').css('opacity', '1');
            } else {
                $('.back-to-top').css('visibility', 'hidden').css('opacity', '0');
            }
        });

        $('.back-to-top').click(function () {
            $('html, body').animate({ scrollTop: 0 }, 800);
        });
    </script>
</body>

</html>