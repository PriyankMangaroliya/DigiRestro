                    <h4>Payment Method</h4>
                    <div class="card-header-action">
                      <select class="form-control d-inline-block" id="paymentMethodYearSelect" style="width: 100px;">
                        <% for(let year=currentYear; year>= 2024; year--) { %>
                          <option value="<%= year %>" <%=year===currentYear ? 'selected' : '' %>>
                            <%= year %>
                          </option>
                          <% } %>
                      </select>
                      <button onclick="downloadChart(chart3Instance, 'png', 'Payment_Method')" class="btn btn-sm btn-primary mx-1">PNG</button>
                      <button onclick="downloadChart(chart3Instance, 'jpg', 'Payment_Method')" class="btn btn-sm btn-warning mx-1">JPG</button>
