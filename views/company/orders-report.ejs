<!doctype html>
<html lang="en" dir="ltr">

<head>
    <title>Orders Report | DigiRestro</title>
</head>

<body>
    <div id="app">
        <div class="main-wrapper main-wrapper-1">
            <%- include("nav-sidebar.ejs", { data: { companies: formattedCompanies } }) %>

                <!-- Main Content -->
                <div class="main-content">
                    <section class="section">
                        <div class="section-body">
                            <div class="row">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header">
                                            <h4>Orders Report Filters</h4>
                                        </div>
                                        <div class="card-body">
                                            <form id="filterForm">
                                                <div class="row">
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Duration</label>
                                                            <select class="form-control" name="duration"
                                                                id="durationSelect">
                                                                <option value="all">All Time</option>
                                                                <option value="day">Today</option>
                                                                <option value="month">Current Month</option>
                                                                <option value="year">Current Year</option>
                                                                <option value="calendar">Custom Range</option>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div id="customDateRange" class="col-md-4 row"
                                                        style="display: none;">
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <label>Start Date</label>
                                                                <input type="date" class="form-control"
                                                                    name="startDate">
                                                            </div>
                                                        </div>
                                                        <div class="col-md-6">
                                                            <div class="form-group">
                                                                <label>End Date</label>
                                                                <input type="date" class="form-control" name="endDate">
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-3">
                                                        <div class="form-group">
                                                            <label>Select Company</label>
                                                            <select class="form-control" name="companyId"
                                                                id="companySelectReport">
                                                                <option value="all">All Companies</option>
                                                                <% formattedCompanies.forEach(c=> { %>
                                                                    <option value="<%= c._id %>">
                                                                        <%= c.company_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2">
                                                        <div class="form-group">
                                                            <label>Select Branch</label>
                                                            <select class="form-control" name="branchId"
                                                                id="branchSelectReport">
                                                                <option value="all">All Branches</option>
                                                                <% branches.forEach(b=> { %>
                                                                    <option value="<%= b._id %>"
                                                                        data-company="<%= b.company_id %>">
                                                                        <%= b.branch_name %>
                                                                    </option>
                                                                    <% }) %>
                                                            </select>
                                                        </div>
                                                    </div>
                                                    <div class="col-md-2 d-flex align-items-end">
                                                        <div class="form-group mb-4">
                                                            <button type="submit" class="btn btn-primary">Apply</button>
                                                            <button type="reset" class="btn btn-secondary ml-2" id="resetBtn">Reset</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header d-flex justify-content-between align-items-center">
                                            <h4>Orders Report</h4>
                                            <div class="card-header-action">
                                                <button onclick="exportToExcel('orderTable', 'OrdersReport')"
                                                    class="btn btn-success mx-1">
                                                    <i class="fas fa-file-excel"></i> Excel
                                                </button>
                                                <button onclick="exportToPDF('orderTable', 'Orders Report')"
                                                    class="btn btn-danger mx-1">
                                                    <i class="fas fa-file-pdf"></i> PDF
                                                </button>
                                                <button onclick="window.print()" class="btn btn-info mx-1">
                                                    <i class="fas fa-print"></i> Print
                                                </button>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <div class="table-responsive">
                                                <table class="table table-striped table-hover" id="orderTable">
                                                    <thead>
                                                        <tr>
                                                            <th>Bill No</th>
                                                            <th>Company</th>
                                                            <th>Branch</th>
                                                            <th>Total Price (₹)</th>
                                                    <th>Payment Mode</th>
                                                    <th>Created At</th>
                                                </tr>
                                            </thead>
                                                    <tbody>
                                                        <!-- Dynamic Content -->
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>
                </div>
        </div>
    </div>


    <!-- Export Libraries -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.25/jspdf.plugin.autotable.min.js"></script>

    <script>
        async function exportToExcel(tableId, title) {
            const table = document.getElementById(tableId);
            const wb = XLSX.utils.table_to_book(table);
            XLSX.writeFile(wb, `${title}.xlsx`);
        }

        async function exportToPDF(tableId, title) {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text(title, 14, 15);
            doc.autoTable({ html: `#${tableId}`, startY: 20 });
            doc.save(`${title}.pdf`);
        }

        $(document).ready(function () {
            // Duration selection logic
            $('#durationSelect').on('change', function () {
                if ($(this).val() === 'calendar') {
                    $('#customDateRange').show();
                } else {
                    $('#customDateRange').hide();
                }
            });

            // Cascading Branch selection logic
            $('#companySelectReport').on('change', function () {
                const companyId = $(this).val();
                $('#branchSelectReport').val('all');
                if (companyId === 'all') {
                    $('#branchSelectReport option').show();
                } else {
                    $('#branchSelectReport option[value!="all"]').hide();
                    $('#branchSelectReport option[data-company="' + companyId + '"]').show();
                }
            });

            // Filter Form submission
            $('#filterForm').on('submit', function (e) {
                e.preventDefault();
                loadOrderData();
        });

        $('#resetBtn').on('click', function() {
            $('#filterForm')[0].reset();
            $('#customDateRange').hide();
            loadOrderData();
            // Need to manually trigger change for select boxes if they rely on it
            $('#companySelectReport').trigger('change');
        });

        function loadOrderData() {
                const formData = $('#filterForm').serialize();
                $('#orderTable tbody').html('<tr><td colspan="7" class="text-center">Loading orders...</td></tr>');

                $.ajax({
                    url: `/company/fetch-orders-report`,
                    type: 'GET',
                    data: formData,
                    success: function (res) {
                        const tbody = $('#orderTable tbody');
                        tbody.empty();

                        if (res.success && res.data.length > 0) {
                            res.data.forEach(function (order) {
                                tbody.append(`<tr>
                                <td>${order.bill_no}</td>
                                <td>${order.company_name}</td>
                                <td>${order.branch_name}</td>
                                <td>${order.total_price}</td>
                                <td><span class="badge badge-info">${order.payment_mode}</span></td>
                                <td>${order.created_at}</td>
                            </tr>`);
                            });
                        } else {
                            tbody.append('<tr><td colspan="7" class="text-center">No orders found matching the criteria.</td></tr>');
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error fetching order data:', error);
                        $('#orderTable tbody').html('<tr><td colspan="7" class="text-center text-danger">Error fetching order data. Please try again.</td></tr>');
                    }
                });
            }

            // Initial load
            loadOrderData();
        });
    </script>

    <!-- General JS Scripts -->
    <script src="assets/js/app.min.js"></script>
    <script src="assets/js/scripts.js"></script>
    <script src="assets/js/custom.js"></script>

    <!-- Template JS File -->
    <script src="assets/bundles/datatables/datatables.min.js"></script>
    <script src="assets/bundles/datatables/DataTables-1.10.16/js/dataTables.bootstrap4.min.js"></script>
    <script src="assets/bundles/jquery-ui/jquery-ui.min.js"></script>
    <script src="assets/js/page/datatables.js"></script>
</body>

</html>
