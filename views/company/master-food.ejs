<!DOCTYPE html>
<html lang="en">

<head>
    <title>Digirestro - Admin</title>
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <style>
        .scrollbar-auto {
            scrollbar-width: auto;
            background-color: lightgreen;
            height: 570px;
            overflow-y: scroll;
        }
    </style>
</head>

<body>
    <div id="app">
        <div class="main-wrapper main-wrapper-1">

            <%- include("nav-sidebar.ejs", { data: { companies: formattedCompanies } }) %>


                <!-- Main Content -->
                <div class="main-content">
                    <!-- write a code -->

                    <section class="section">
                        <div class="section-body">
                            <div class="row">
                                <div class="col-12">
                                    <div class="card">
                                        <div class="card-header d-flex justify-content-between align-items-center">
                                            <h4>Food</h4>
                                            <div class="buttons">
                                                <a href="javascript:void(0)"
                                                    class="settingPanelToggle btn btn-primary addbtn">Add
                                                    Food</a>
                                            </div>
                                        </div>
                                        <div class="card-body">
                                            <div class="table-responsive">
                                                <table class="table table-striped table-hover" id="table-1"
                                                    style="width:100%;">
                                                    <thead>
                                                        <tr>
                                                            <th>No</th>
                                                            <th>Food Name</th>
                                                            <th>Description</th>
                                                            <th>Sub Category</th>
                                                            <th>Food Type</th>
                                                            <th>Status</th>
                                                            <th>Action</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% if (foodItems.length> 0) { %>
                                                            <% for (let i=0; i < foodItems.length; i++) { %>
                                                                <tr>
                                                                    <td>
                                                                        <%= i + 1 %>
                                                                    </td>
                                                                    <td>
                                                                        <%= foodItems[i].item_name %>
                                                                    </td>
                                                                    <td>
                                                                        <%= foodItems[i].description %>
                                                                    </td>
                                                                    <% let
                                                                        matchingSubCategory=foodSubCategories.find(subCategory=>
                                                                        subCategory._id.equals(foodItems[i].food_sub_category_id));
                                                                        %>
                                                                        <% if (matchingSubCategory) { %>
                                                                            <td>
                                                                                <%= matchingSubCategory.sub_category_name
                                                                                    %>
                                                                            </td>
                                                                            <% } else { %>
                                                                                <td>No Category</td>
                                                                                <% } %>
                                                                                    <td>
                                                                                        <%= ['Veg', 'Egg' , 'Non-Veg'
                                                                                            ][foodItems[i].food_type -
                                                                                            1] %>
                                                                                    </td>
                                                                                    <td>
                                                                                        <% if(foodItems[i].is_active==true){
                                                                                            %>
                                                                                            <a href="/company/food-item-activeAndDeactive?id=<%= foodItems[i]._id %>&value=true"
                                                                                                class="badge badge-success badge-shadow">Active</a>
                                                                                            <% }else { %>
                                                                                                <a href="/company/food-item-activeAndDeactive?id=<%= foodItems[i]._id %>&value=false"
                                                                                                    class="badge badge-danger badge-shadow">Deactive</a>
                                                                                                <% } %>
                                                                                    </td>
                                                                                    <td>
                                                                                        <a href="javascript:void(0)"
                                                                                            class="settingPanelToggle updatebtn btn btn-primary"
                                                                                            data-id="<%= foodItems[i]._id %>"
                                                                                            data-name="<%= foodItems[i].item_name %>"
                                                                                            data-description="<%= foodItems[i].description %>"
                                                                                            data-sub-category-id="<%= foodItems[i].food_sub_category_id %>"
                                                                                            data-food-type="<%= foodItems[i].food_type %>"
                                                                                            onclick="updateFoodData(this)">
                                                                                            <i class="fas fa-edit"></i>
                                                                                        </a>
                                                                                        <a href="javascript:void(0)"
                                                                                            class="btn btn-danger"
                                                                                            data-id="<%= foodItems[i]._id %>"
                                                                                            onclick="Aredelete(this)">
                                                                                            <i class="fas fa-trash"></i>
                                                                                        </a>
                                                                                        <!--                                                        <a href="#" class="btn btn-success"-->
                                                                                        <!--                                                           data-category-id="<%= foodItems[i]._id %>"-->
                                                                                        <!--                                                           onclick=""><i class="fas fa-eye"></i></a>-->
                                                                                    </td>

                                                                </tr>
                                                                <% } %>
                                                                    <% } else { %>
                                                                        <tr>
                                                                            <td colspan="7" class="text-center">No food
                                                                                items found.
                                                                            </td>
                                                                        </tr>
                                                                        <% } %>
                                                                            <!--                                            <tr>-->
                                                                            <!--                                                <td>1</td>-->
                                                                            <!--                                                <td>Pani puri</td>-->
                                                                            <!--                                                <td>Seven Flevar Pani puri</td>-->
                                                                            <!--                                                <td>Gujrati</td>-->
                                                                            <!--                                                <td>Fast Food</td>-->
                                                                            <!--                                                <td>Vej</td>-->
                                                                            <!--                                                <td>-->
                                                                            <!--                                                    5 Puri<br/>-->
                                                                            <!--                                                    7 Puri<br/>-->
                                                                            <!--                                                    10 Puri<br/>-->
                                                                            <!--                                                </td>-->
                                                                            <!--                                                <td>-->
                                                                            <!--                                                    50<br/>-->
                                                                            <!--                                                    70<br/>-->
                                                                            <!--                                                    100<br/>-->
                                                                            <!--                                                </td>-->
                                                                            <!--                                                <td>-->
                                                                            <!--                                                    <div class="">Active</div>-->
                                                                            <!--                                                    <div class="">Active</div>-->
                                                                            <!--                                                    <div class="">Deactive</div>-->
                                                                            <!--                                                </td>-->
                                                                            <!--                                                <td>-->
                                                                            <!--                                                    <a href="javascript:void(0)"-->
                                                                            <!--                                                       class="settingPanelToggle updatebtn btn btn-primary"-->
                                                                            <!--                                                       onclick="updateData('1')">-->
                                                                            <!--                                                        <i class="fas fa-edit"></i></a>-->
                                                                            <!--                                                    <a href="#" class="btn btn-danger"><i class="fas fa-trash"></i></a>-->
                                                                            <!--                                                </td>-->
                                                                            <!--                                            </tr>-->
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    <% if(foodSubCategories.length===0){ %>
                        <div class="settingSidebar settingSidebar2 add">
                            <div class="fade show active ">
                                <div class="setting-panel-header">Food</div>
                                <div class="card m-4 pb-4 pt-4">
                                    <center>
                                        <h5>Please enter food Sub categories</h5>
                                        <a href="/company/manage-sub-category" class="btn btn-primary">Add Sub
                                            categories</a>
                                    </center>
                                </div>
                            </div>
                        </div>

                        <% }else { %>
                            <div class="settingSidebar settingSidebar2 add">
                                <div class="fade show active ">
                                    <div class="setting-panel-header">Food</div>
                                    <div class="card m-4 scrollbar-auto">
                                        <form class="needs-validation" novalidate="" action="/company/add-food-item"
                                            method="post">
                                            <div class="card-header">
                                                <h4>Add Food</h4>
                                            </div>
                                            <div class="card-body">
                                                <div class="form-row">
                                                    <div class="form-group col-md-5">
                                                        <label>Food Name</label>
                                                        <input type="text" class="form-control" name="item_name"
                                                            placeholder="Food Name" required="">
                                                        <div class="invalid-feedback">
                                                            What's Food Name?
                                                        </div>
                                                    </div>

                                                    <div class="form-group col-md-7">
                                                        <label>Food Description</label>
                                                        <input type="text" class="form-control" name="description"
                                                            placeholder="Food Description" required="">
                                                        <div class="invalid-feedback">
                                                            What's Food Description?
                                                        </div>
                                                    </div>
                                                </div>
                                                <div class="form-row">
                                                    <div class="form-group col-md-5">
                                                        <label>Food Sub Category</label>
                                                        <select class="form-control" required
                                                            name="food_sub_category_id">
                                                            <% for (let i=0; i < foodSubCategories.length; i++) { %>
                                                                <option value="<%= foodSubCategories[i]._id %>">
                                                                    <%= foodSubCategories[i].sub_category_name %>
                                                                </option>
                                                                <% } %>
                                                        </select>
                                                        <div class="invalid-feedback">
                                                            What's Food Sub Category?
                                                        </div>
                                                    </div>
                                                    <div class="form-group col-md-4">
                                                        <label>Food Type</label>
                                                        <select class="form-control" required name="food_type">
                                                            <option value="1">Veg</option>
                                                            <option value="2">Egg</option>
                                                            <option value="3">Non-Veg</option>
                                                        </select>
                                                        <div class="invalid-feedback">
                                                            What's Food Type?
                                                        </div>
                                                    </div>
                                                    <div class="form-group col-md-3">
                                                        <label>No of Sub Food</label>
                                                        <select class="form-control" required name="no_of_sub_food"
                                                            id="no_of_sub_food">
                                                            <option value="1">1</option>
                                                            <option value="2">2</option>
                                                            <option value="3">3</option>
                                                            <option value="4">4</option>
                                                            <option value="5">5</option>
                                                            <option value="6">6</option>
                                                        </select>
                                                    </div>
                                                </div>

                                                <br />

                                                <div id="dynamic-form-container">
                                                    <!-- Dynamic form content will be appended here -->
                                                </div>
                                            </div>

                                            <div class="card-footer">
                                                <input type="submit" class="btn btn-primary" id="add" value="Add Food">

                                                <a href="javascript:void(0)"
                                                    class="addbtn btn btn-icon icon-left btn-primary btn-restore-theme">Cancel</a>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                            <% } %>

                                <div class="settingSidebar settingSidebar2 update">
                                    <div class="fade show active">
                                        <div class="setting-panel-header">Food</div>
                                        <div class="card m-4 scrollbar-auto">
                                            <form class="needs-validation" novalidate=""
                                                action="/company/update-food-item" method="post">
                                                <div class="card-header">
                                                    <h4>Update Food</h4>
                                                </div>
                                                <div class="card-body">
                                                    <input type="hidden" name="food_item_id" id="update_food_item_id">
                                                    <div class="form-row">
                                                        <div class="form-group col-md-5">
                                                            <label>Food Name</label>
                                                            <input type="text" class="form-control" name="item_name"
                                                                id="update_item_name" placeholder="Food Name"
                                                                required="">
                                                            <div class="invalid-feedback">
                                                                What's Food Name?
                                                            </div>
                                                        </div>

                                                        <div class="form-group col-md-7">
                                                            <label>Food Description</label>
                                                            <input type="text" class="form-control" name="description"
                                                                id="update_description" placeholder="Food Description"
                                                                required="">
                                                            <div class="invalid-feedback">
                                                                What's Food Description?
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="form-row">
                                                        <div class="form-group col-md-5">
                                                            <label>Food Sub Category</label>
                                                            <select class="form-control" required
                                                                name="food_sub_category_id"
                                                                id="update_food_sub_category_id">
                                                                <% for (let i=0; i < foodSubCategories.length; i++) { %>
                                                                    <option value="<%= foodSubCategories[i]._id %>">
                                                                        <%= foodSubCategories[i].sub_category_name %>
                                                                    </option>
                                                                    <% } %>
                                                            </select>
                                                            <div class="invalid-feedback">
                                                                What's Food Sub Category?
                                                            </div>
                                                        </div>
                                                        <div class="form-group col-md-4">
                                                            <label>Food Type</label>
                                                            <select class="form-control" required name="food_type"
                                                                id="update_food_type">
                                                                <option value="1">Veg</option>
                                                                <option value="2">Egg</option>
                                                                <option value="3">Non-Veg</option>
                                                            </select>
                                                            <div class="invalid-feedback">
                                                                What's Food Type?
                                                            </div>
                                                        </div>
                                                        <div class="form-group col-md-3">
                                                            <label>No of Sub Food</label>
                                                            <select class="form-control" required name="no_of_sub_food"
                                                                id="no_of_sub_food_update">
                                                                <option value="1">1</option>
                                                                <option value="2">2</option>
                                                                <option value="3">3</option>
                                                                <option value="4">4</option>
                                                                <option value="5">5</option>
                                                                <option value="6">6</option>
                                                            </select>
                                                        </div>
                                                    </div>

                                                    <br />

                                                    <div id="dynamic-form-container-update">
                                                        <!-- Dynamic form content will be appended here -->
                                                    </div>
                                                </div>

                                                <div class="card-footer">
                                                    <input type="submit" class="btn btn-primary" name="update"
                                                        id="update" value="Update Food">

                                                    <a href="javascript:void(0)"
                                                        class="updatebtn btn btn-icon icon-left btn-primary btn-restore-theme">Cancel</a>
                                                </div>
                                            </form>
                                        </div>
                                    </div>
                                </div>

                </div>

        </div>
    </div>

    <!-- Hidden data for JavaScript -->
    <div id="food-sub-items-data" style="display: none;"><%= JSON.stringify(foodSubItems || []) %></div>

    <script>
        const allFoodSubItems = JSON.parse($('#food-sub-items-data').text());
        console.log("All Food Sub Items:", allFoodSubItems);

        // Function to generate dynamic form based on selected value
        function generateDynamicForm(containerId, countId) {
            console.log("generateDynamicForm called for container:", containerId, "countId:", countId);
            var countElement = $('#' + countId);
            var container = $('#' + containerId);

            if (countElement.length === 0 || container.length === 0) {
                console.error("Required elements not found:", { countId, containerId });
                return;
            }

            var numberOfSubFood = parseInt(countElement.val()) || 0;
            console.log("Generating", numberOfSubFood, "sub food fields in", containerId);

            // Clear previous dynamic form content
            container.empty();

            // Generate dynamic form content
            for (var i = 0; i < numberOfSubFood; i++) {
                var dynamicForm = `
        <div class="form-row" id="sub_food_${i + 1}">
          <div class="form-group col-md-8">
            <label>Sub Food Name ${i + 1}</label>
            <input type="text" class="form-control" name="sub_item_name_${i + 1}" placeholder="Sub Food Name" required="">
            <div class="invalid-feedback">
              What's Sub Food Name?
            </div>
          </div>

          <div class="form-group col-md-4">
            <label>Food Price ${i + 1}</label>
            <input type="text" class="form-control" name="price_${i + 1}" placeholder="Food Price" required="">
            <div class="invalid-feedback">
              What's Food Price?
            </div>
          </div>
        </div>
      `;

                // Append dynamic form content to container
                container.append(dynamicForm);
            }
            console.log("Dynamic form generation complete");
        }

        $(document).ready(function () {
            // Attach event listeners to the select elements
            $('#no_of_sub_food').on('change', function () {
                generateDynamicForm('dynamic-form-container', 'no_of_sub_food');
            });

            $('#no_of_sub_food_update').on('change', function () {
                generateDynamicForm('dynamic-form-container-update', 'no_of_sub_food_update');
            });

            // Initial form generation on page load
            generateDynamicForm('dynamic-form-container', 'no_of_sub_food');

            // Ensure form is generated when sidebars are opened
            $('.addbtn').on('click', function () {
                generateDynamicForm('dynamic-form-container', 'no_of_sub_food');
            });
        });


        function updateFoodData(element) {
            const id = $(element).data('id');
            const name = $(element).data('name');
            const desc = $(element).data('description');
            const subCatId = $(element).data('sub-category-id');
            const type = $(element).data('food-type');

            console.log("updateFoodData called for id:", id);
            $('#update_food_item_id').val(id);
            $('#update_item_name').val(name);
            $('#update_description').val(desc);
            $('#update_food_sub_category_id').val(subCatId);
            $('#update_food_type').val(type);

            // Filter sub-items for this food item (using String to avoid ObjectId mismatch)
            const currentSubItems = allFoodSubItems.filter(si => String(si.food_item_id) === String(id));
            console.log("Current sub items found for food " + id + ":", currentSubItems.length);

            // Update "No of Sub Food" selector
            $('#no_of_sub_food_update').val(currentSubItems.length || 1);

            // Generate the dynamic form
            generateDynamicForm('dynamic-form-container-update', 'no_of_sub_food_update');

            // Populate the fields
            currentSubItems.forEach((si, index) => {
                $(`input[name="sub_item_name_${index + 1}"]`, '#dynamic-form-container-update').val(si.sub_item_name);
                $(`input[name="price_${index + 1}"]`, '#dynamic-form-container-update').val(si.price);
            });
        }

        function Aredelete(element) {
            const foodItemId = $(element).data('id');
            Swal.fire({
                title: "Are you sure?",
                text: "You won't be able to revert this!",
                icon: "warning",
                showCancelButton: true,
                confirmButtonColor: "#3085d6",
                cancelButtonColor: "#d33",
                confirmButtonText: "Yes, delete it!"
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        type: "POST",
                        url: "/company/delete-food-item?id=" + foodItemId,
                        success: function (response) {
                            if (response.success) {
                                window.location.href = "/company/manage-food";
                            } else {
                                iziToast.error({
                                    title: 'Error',
                                    message: response.message || 'Failed to delete the record.',
                                    position: 'topRight'
                                });
                            }
                        },
                        error: function (error) {
                            iziToast.error({
                                title: 'Error',
                                message: 'Failed to delete the record.',
                                position: 'topRight'
                            });
                        }
                    });
                }
            });
        }
    </script>


    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- General JS Scripts -->
    <script src="assets/js/app.min.js"></script>
    <!-- JS Libraies -->
    <script src="assets/bundles/datatables/datatables.min.js"></script>
    <script src="assets/bundles/datatables/DataTables-1.10.16/js/dataTables.bootstrap4.min.js"></script>
    <script src="assets/bundles/jquery-ui/jquery-ui.min.js"></script>
    <!-- Page Specific JS File -->
    <script src="assets/js/page/datatables.js"></script>
    <!-- Template JS File -->
    <script src="assets/js/scripts.js"></script>
    <!-- Custom JS File -->
    <script src="assets/js/custom.js"></script>

</body>

</html>