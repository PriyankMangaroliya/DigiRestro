<!DOCTYPE html>
<html lang="en">
<head>
    <title>Digirestro - Admin</title>
</head>

<body>
<div id="app">
    <div class="main-wrapper main-wrapper-1">
        <%- include("nav-sidebar.ejs") %>

        <!-- Main Content -->
        <div class="main-content">
            <!-- write a code -->

            <section class="section">
                <div class="section-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    <h4>Branches</h4>
                                </div>
                                <div class="card-body">
                                    <div class="table-responsive">
                                        <table class="table table-striped table-hover" id="table-1" style="width:100%;">
                                            <thead>
                                            <tr>
                                                <th>Index</th>
                                                <!-- <th>Company Logo</th> -->
                                                <th>Branch Name</th>
                                                <th>Country</th>
                                                <th>State</th>
                                                <th>City</th>
                                                <th>Street Address</th>
                                                <th>Pincode</th>
                                                <th>Created At</th>
                                                <th>Updated At</th>
                                            </tr>
                                            </thead>
                                            <tbody>
                                                <% for(let i = 0; i < branchDetails.length; i++){ %>
                                                    <tr>
                                                        <td><%= i + 1 %></td>
                                                        <!-- <td>
                                                            <img alt="image" src="assets/img/cards/mastercard.png"
                                                                 width="50">
                                                        </td> -->
                                                        <td><%= branchDetails[i].branch_name %></td>
                                                        <td><%= branchDetails[i].country %></td>
    
                                                        <td><%= branchDetails[i].state %></td>
                                                        <td><%= branchDetails[i].city %></td>
                                                        <td><%= branchDetails[i].street_address %></td>
                                                        <td><%= branchDetails[i].pin_code %></td>
                                                        
                                                        <td>
                                                            <%= branchDetails[i].created_at.toLocaleString('en-US', {
                                                                weekday: 'short',
                                                                day: 'numeric',
                                                                month: 'short',
                                                                year: 'numeric'
                                                            }) %>
                                                            <br>
                                                            <%= branchDetails[i].created_at.toLocaleString('en-US', {
                                                                hour: '2-digit',
                                                                minute: '2-digit',
                                                                second: '2-digit'
                                                            }) %>
    
                                                        </td>
                                                        <td>
                                                            <%= branchDetails[i].updated_at.toLocaleString('en-US', {
                                                                weekday: 'short',
                                                                day: 'numeric',
                                                                month: 'short',
                                                                year: 'numeric'
                                                            }) %>
                                                            <br>
                                                            <%= branchDetails[i].updated_at.toLocaleString('en-US', {
                                                                hour: '2-digit',
                                                                minute: '2-digit',
                                                                second: '2-digit'
                                                            }) %>
                                                        </td>
                                                    </tr>
                                                <% } %>
                                            </tbody>
                                            <!-- <td>
                                                    <div class="badge badge-success badge-shadow">Active</div>
                                                </td> -->
                                        </table>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

        </div>

    </div>
</div>
<script src="../admin/assets/js/page/datatables.js"></script>
</body>
</html>