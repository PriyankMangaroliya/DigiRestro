<!-- ===== Branch Responsive Styles ===== -->
<style>
/* ---- Hamburger Toggle Button ---- */
.branch-sidebar-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px 10px;
    margin-right: 10px;
    border-radius: 8px;
    transition: background 0.2s;
    flex-shrink: 0;
}
.branch-sidebar-toggle:hover { background: rgba(234,106,18,0.1); }
.branch-sidebar-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #ea6a12;
    margin: 5px 0;
    border-radius: 2px;
    transition: all 0.3s ease;
}

/* ---- Sidebar Backdrop (mobile overlay) ---- */
.sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 1040;
}
body.sidebar-open .sidebar-backdrop { display: block; }

/* ---- Table boxes: fluid flex wrap ---- */
.table-box-wrap { display: flex; flex-wrap: wrap; gap: 10px; }
.table-box-wrap .box { flex: 0 0 auto; }

/* ---- Status legend row ---- */
.table-legend-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    align-items: center;
    justify-content: flex-end;
    margin-bottom: 12px;
}
.table-legend-row p {
    margin: 0 !important;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 0.8rem;
}

/* ---- New Order button: hidden on xs ---- */
@media (max-width: 575.98px) {
    .nav-new-order-wrap { display: none; }
}

/* ============================================================
   TABLET / MOBILE  < 992px  — Sidebar becomes a drawer
   ============================================================ */
@media (max-width: 991.98px) {

    /* Show hamburger */
    .branch-sidebar-toggle {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

    /* Sidebar: slide off-screen by default */
    .sidebar {
        position: fixed !important;
        top: 0 !important;
        left: 0 !important;
        height: 100vh !important;
        width: 260px !important;
        min-width: 260px !important;
        transform: translateX(-270px) !important;
        transition: transform 0.3s ease !important;
        z-index: 1050 !important;
        overflow-y: auto !important;
    }

    /* Sidebar visible when body.sidebar-open */
    body.sidebar-open .sidebar {
        transform: translateX(0) !important;
    }

    /* Main content: full width (no sidebar offset) */
    .main-content {
        margin-left: 0 !important;
        padding-left: 0 !important;
        width: 100% !important;
    }

    /* Nav adjustments */
    .iq-navbar .container-fluid { flex-wrap: nowrap; gap: 8px; }
    .iq-navbar h3 { font-size: 1.1rem; white-space: nowrap; }
    .iq-navbar .btn-primary.rounded-pill {
        font-size: 0.8rem;
        padding: 4px 10px;
        white-space: nowrap;
    }
}

/* ============================================================
   MOBILE  < 768px  — Stack all multi-column layouts
   ============================================================ */
@media (max-width: 767.98px) {

    /* All grid columns → full width */
    .col-lg-2, .col-lg-3, .col-lg-4, .col-lg-5, .col-lg-6,
    .col-lg-7, .col-lg-8,
    .col-xl-3, .col-xl-4, .col-xl-8, .col-xl-9 {
        width: 100% !important;
        flex: 0 0 100% !important;
        max-width: 100% !important;
    }

    /* Fix any hardcoded width on order table */
    .table-responsive.border.border-danger { width: 100% !important; }

    /* Compact content padding */
    .content-inner {
        padding-left: 8px !important;
        padding-right: 8px !important;
    }

    /* Smaller table boxes */
    .box {
        width: 100px !important;
        height: 100px !important;
        font-size: 0.85rem;
    }

    .iq-navbar .btn-primary.rounded-pill {
        font-size: 0.75rem;
        padding: 3px 8px;
    }
}

/* ============================================================
   SMALL MOBILE  < 576px
   ============================================================ */
@media (max-width: 575.98px) {
    .iq-navbar h3 { font-size: 1rem; }
    .box { width: 86px !important; height: 86px !important; }
    .table-legend-row p { font-size: 0.72rem; padding: 3px 8px; }
    .form-group { margin-bottom: 1rem; }
    .form-group label { font-size: 0.85rem; }
}
</style>

