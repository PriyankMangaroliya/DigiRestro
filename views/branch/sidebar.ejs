<% if (typeof Success !== 'undefined' && Success.length > 0) { %>
    <script>
        iziToast.success({
            title: 'Success',
            message: '<%= Success %>',
            position: 'topRight'
        });
    </script>
<% } %>

<% if (typeof Error !== 'undefined' && Error.length > 0) { %>
    <script>
        iziToast.error({
            title: 'Error',
            message: '<%= Error %>',
            position: 'topRight'
        });
    </script>
<% } %>
